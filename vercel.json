{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "git": {
    "deploymentEnabled": {
      "dev": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/incomplete-actors-reminder",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/cron/receipt-reminder",
      "schedule": "0 15 1 * *"
    },
    {
      "path": "/api/cron/policy-expiry",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/policy-expiration-reminder",
      "schedule": "0 13 * * *"
    }
  ]
}
