# Test Environment Configuration
# Loaded automatically by `bun test` when NODE_ENV=test.
# DO NOT point this at a non-test database — preload.ts asserts the URL ends in `_test`.

# Database — dockerized Postgres on 5433 (see docker-compose.test.yml)
DATABASE_URL="postgresql://test:test@localhost:5433/hestia_test"

# Authentication
JWT_SECRET="test-jwt-secret-key"
NEXTAUTH_SECRET="test-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Email (mocked at preload — values irrelevant)
SMTP_HOST="smtp.test"
SMTP_PORT="587"
SMTP_USER="test"
SMTP_PASS="test"
EMAIL_FROM="test@hestia.com"

# File Storage (mocked at preload — values irrelevant)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"
AWS_S3_BUCKET="test-bucket"

# Stripe (mocked at preload — values irrelevant)
STRIPE_SECRET_KEY="sk_test_example"
STRIPE_WEBHOOK_SECRET="whsec_test"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_example"

# Google Maps (mocked at preload — values irrelevant)
GOOGLE_MAPS_API_KEY="test"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="test"
DEMO_MODE="false"
