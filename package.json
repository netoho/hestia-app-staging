{
  "name": "hestiaplp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --bun next dev --turbopack -p 9002",
    "dev:node": "next dev --turbopack -p 9002",
    "build": "bun run --bun next build",
    "build:analyze": "ANALYZE=true bun run --bun next build",
    "start": "bun run --bun next start",
    "lint": "eslint src",
    "typecheck": "bun run --bun tsc --noEmit",
    "typecheck:ratchet": "bun run scripts/tsc-ratchet.ts",
    "db:seed": "bun run prisma db seed",
    "db:reset": "bun run --bun prisma db push --force-reset",
    "postinstall": "bun run --bun prisma generate",
    "generate-enums": "bun run scripts/generate-enums.ts",
    "cover:fixture": "bun run scripts/generateCoverFixture.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test src/",
    "test:watch": "bun test --watch src/",
    "test:integration": "NODE_ENV=test dotenv -e .env.test -e .env.test.local -o -- bun test --preload ./tests/integration/preload.ts tests/integration",
    "test:integration:filter": "NODE_ENV=test dotenv -e .env.test -e .env.test.local -o -- bun test --preload ./tests/integration/preload.ts",
    "test:integration:no-docker": "NODE_ENV=test dotenv -e .env.test -e .env.test.local -o -- bun test --preload ./tests/integration/preload.ts tests/integration",
    "pretest:integration": "bun run test:db:setup",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:setup": "bun run test:db:up && NODE_ENV=test dotenv -e .env.test -e .env.test.local -o -- bun run scripts/test-db.ts setup",
    "test:db:provision": "NODE_ENV=test dotenv -e .env.test -e .env.test.local -o -- bun run scripts/test-db.ts setup",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:db:reset": "docker compose -f docker-compose.test.yml down -v && bun run test:db:setup",
    "pretest:e2e": "bun run test:db:up && bun run test:e2e:provision",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:provision": "DATABASE_URL='postgresql://test:test@localhost:5433/hestia_e2e_test' bun run scripts/test-db.ts setup",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "dev:e2e": "DATABASE_URL='postgresql://test:test@localhost:5433/hestia_e2e_test' NEXTAUTH_URL='http://localhost:9002' NEXTAUTH_SECRET='e2e-nextauth-secret' JWT_SECRET='e2e-jwt-secret' NEXT_PUBLIC_APP_URL='http://localhost:9002' STORAGE_PROVIDER=s3 AWS_ACCESS_KEY_ID=minioadmin AWS_SECRET_ACCESS_KEY=minioadmin AWS_S3_BUCKET=hestia-e2e AWS_S3_REGION=us-east-1 AWS_REGION=us-east-1 AWS_S3_ENDPOINT='http://localhost:9100' bun run --bun next dev --turbopack -p 9002"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/s3-request-presigner": "^3.883.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-email/components": "^0.3.2",
    "@react-email/render": "^1.1.3",
    "@react-pdf/renderer": "^4.3.2",
    "@tanstack/react-query": "^5.90.10",
    "@trpc/client": "^11.7.1",
    "@trpc/react-query": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "docx": "^9.6.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.475.0",
    "mailgun.js": "^12.0.3",
    "next": "15.5.20",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.5",
    "papaparse": "^5.5.3",
    "pg": "^8.12.0",
    "react": "19.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "19.2.0",
    "react-email": "^4.2.4",
    "react-hook-form": "^7.66.1",
    "recharts": "^2.15.1",
    "resend": "^4.6.0",
    "server-only": "^0.0.1",
    "stripe": "^18.3.0",
    "superjson": "^2.2.5",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.4",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.17",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/stripe": "^8.0.417",
    "@types/uuid": "^11.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.6.0",
    "fishery": "^2.4.0",
    "jszip": "^3.10.1",
    "postcss": "^8.5.10",
    "prisma": "^7.0.1",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.16.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.1"
  }
}
